# ==============================================================================
# AARAVAM 26 - ENVIRONMENT VARIABLES EXAMPLE CONFIGURATION
# ------------------------------------------------------------------------------
# Copy this file to '.env' and fill in the values.
# NEVER commit the actual '.env' file containing secrets to version control.
# ==============================================================================

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================

# Why it exists: The base URL of your Supabase project instance, used to route API requests.
# Where to obtain it: Supabase Dashboard -> Project Settings -> API -> Project URL.
# Security: Frontend-safe (prefixed with VITE_ to expose to client bundle).
VITE_SUPABASE_URL=https://your-project.supabase.co

# Why it exists: The public anonymous API key used to make safe public queries.
# Where to obtain it: Supabase Dashboard -> Project Settings -> API -> anon public key.
# Security: Frontend-safe (prefixed with VITE_ to expose to client bundle).
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Why it exists: The high-privilege service role key used to bypass Row Level Security.
# Where to obtain it: Supabase Dashboard -> Project Settings -> API -> service_role key.
# Security: SERVER-ONLY. NEVER expose this key to the frontend or git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ==============================================================================
# POSTHOG ANALYTICS (OPTIONAL)
# ==============================================================================

# Why it exists: The public API key used to send tracking and product analytics to PostHog.
# Where to obtain it: PostHog Dashboard -> Project Settings -> Project API Key.
# Security: Frontend-safe (prefixed with VITE_ to expose to client bundle).
VITE_POSTHOG_KEY=your-posthog-key-here

# Why it exists: The API host endpoint where PostHog ingestion requests are sent.
# Where to obtain it: Default is 'https://app.posthog.com' (US) or 'https://eu.posthog.com' (EU).
# Security: Frontend-safe.
VITE_POSTHOG_HOST=https://app.posthog.com


# ==============================================================================
# CLOUDINARY (OPTIONAL)
# ==============================================================================

# Why it exists: The cloud name for media asset uploads.
# Where to obtain it: Cloudinary Dashboard -> Product Environment Settings.
# Security: Frontend-safe if doing client-side uploads, otherwise server-only.
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Why it exists: The API identifier key for authenticating Cloudinary uploads.
# Where to obtain it: Cloudinary Dashboard -> Product Environment Settings.
# Security: SERVER-ONLY (or frontend-safe if signing uploads client-side).
CLOUDINARY_API_KEY=your-cloudinary-api-key

# Why it exists: The API signing secret used for secure authenticated requests.
# Where to obtain it: Cloudinary Dashboard -> Product Environment Settings.
# Security: SERVER-ONLY. MUST NEVER be exposed to the client.
CLOUDINARY_API_SECRET=your-cloudinary-api-secret


# ==============================================================================
# RESEND EMAILS (OPTIONAL)
# ==============================================================================

# Why it exists: The API key for Resend email service, used to send transactional emails.
# Where to obtain it: Resend Dashboard -> API Keys.
# Security: SERVER-ONLY. MUST NEVER be exposed to the client.
RESEND_API_KEY=re_your_api_key_here


# ==============================================================================
# CLOUDFLARE TURNSTILE (ANTI-SPAM PROTECTION)
# ==============================================================================

# Why it exists: The public site key for displaying the Turnstile anti-bot widget.
# Where to obtain it: Cloudflare Dashboard -> Turnstile -> Add Site -> Site Key.
# Security: Frontend-safe.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Why it exists: The secret key used to verify the Turnstile widget challenge token on the server.
# Where to obtain it: Cloudflare Dashboard -> Turnstile -> Add Site -> Secret Key.
# Security: SERVER-ONLY. MUST NEVER be exposed to the client.
TURNSTILE_SECRET_KEY=your-turnstile-secret-key


# ==============================================================================
# OPENAI MODERATION (OPTIONAL)
# ==============================================================================

# Why it exists: API key for OpenAI used to run AI-based moderation or toxicity filtering.
# Where to obtain it: OpenAI Platform Dashboard -> API Keys.
# Security: SERVER-ONLY. MUST NEVER be exposed to the client.
OPENAI_API_KEY=sk-proj-your-openai-api-key


# ==============================================================================
# APP CONFIG
# ==============================================================================

# Why it exists: The user-facing name of the application.
# Where to obtain it: Configured by developer/owner.
# Security: Frontend-safe.
VITE_APP_NAME=Aaravam 26

# Why it exists: The primary production URL of the deployed application, used for absolute URLs and redirects.
# Where to obtain it: Configured by developer/owner (e.g. Vercel deployment URL).
# Security: Frontend-safe.
VITE_APP_URL=http://localhost:3000
